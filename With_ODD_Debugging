// --- NAVIGATION HELPERS ---
bool isLine(uint8_t pin) {
  return (digitalRead(pin) == LOW);
}

float getDistance() {
  digitalWrite(PIN_TRIG, LOW);
  delayMicroseconds(2);
  digitalWrite(PIN_TRIG, HIGH);
  delayMicroseconds(10);
  digitalWrite(PIN_TRIG, LOW);
  long duration = pulseIn(PIN_ECHO, HIGH, 30000); 
  if (duration == 0) return 999.0; 
  return (duration * 0.034 / 2);
}

// --- MONITORING HELPERS ---
float getAccuratePercentage(float v, int i) {
    float vpc = v / CELLS[i]; 
    float p = 0;
    if (vpc >= 4.20) p = 100.0;
    else if (vpc >= 4.00) p = 84.0 + (vpc - 4.00) * 80.0;  
    else if (vpc >= 3.80) p = 50.0 + (vpc - 3.80) * 170.0; 
    else if (vpc >= 3.70) p = 15.0 + (vpc - 3.70) * 350.0; 
    else if (vpc >= 3.30) p = 0.0 + (vpc - 3.30) * 37.5;   
    else p = 0.0;
    return p;
}

float readStableVoltage(uint8_t pin, float ratio, int chIdx) {
    long rawSum = 0;
    for(int i=0; i<400; i++) rawSum += analogRead(pin);
    float rawAvg = rawSum / 400.0;
    float batteryV = (rawAvg / 4095.0) * 3.3 * ratio;

    if (v_filter[chIdx] == 0) v_filter[chIdx] = batteryV;
    v_filter[chIdx] = (v_filter[chIdx] * 0.95) + (batteryV * 0.05);
    
    return v_filter[chIdx];
}

float readCurrent(uint8_t pin) {
  int rawADC = analogRead(pin);
  float voltage = (rawADC / 4095.0) * 3.3; 
  float current = (voltage - 1.65) / CURRENT_SENSITIVITY;
  return (current < 0) ? 0 : current; 
}

// --- MOTOR CONTROL ---
void stopMotor(uint8_t chGreen, uint8_t chRed) {
  ledcWrite(chGreen, 0); ledcWrite(chRed, 0);
}

void driveNormal(uint8_t chGreen, uint8_t chRed, int speed, bool forward) {
  if (forward) { ledcWrite(chGreen, speed); ledcWrite(chRed, 0); } 
  else { ledcWrite(chGreen, 0); ledcWrite(chRed, speed); }
}

void driveSwapped(uint8_t chGreen, uint8_t chRed, int speed, bool forward) {
  if (forward) { ledcWrite(chGreen, 0); ledcWrite(chRed, speed); } 
  else { ledcWrite(chGreen, speed); ledcWrite(chRed, 0); }
}

void stopAllMotors() {
  stopMotor(CH_FL_G, CH_FL_R); stopMotor(CH_FR_G, CH_FR_R);
  stopMotor(CH_RL_G, CH_RL_R); stopMotor(CH_RR_G, CH_RR_R);
}

void driveLeftSide(int speed) {
  bool fwd = speed >= 0;
  int pwm = constrain(abs(speed), 0, 255);
  driveSwapped(CH_FL_G, CH_FL_R, pwm, fwd);
  driveNormal(CH_RL_G, CH_RL_R, pwm, fwd);
}

void driveRightSide(int speed) {
  bool fwd = speed >= 0;
  int pwm = constrain(abs(speed), 0, 255);
  driveNormal(CH_FR_G, CH_FR_R, pwm, fwd);
  driveSwapped(CH_RR_G, CH_RR_R, pwm, fwd);
}

void rotateLeft() { driveLeftSide(-turnSpeed); driveRightSide(turnSpeed); }
void rotateRight() { driveLeftSide(turnSpeed); driveRightSide(-turnSpeed); }
void moveReverse() { driveLeftSide(-170); driveRightSide(-170); }

